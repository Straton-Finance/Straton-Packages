{
  "name": "straton-packages",
  "version": "0.0.0",
  "private": true,
  "description": "Shared packages for the Straton RWAFi platform",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules",
    "changeset": "changeset",
    "version": "changeset version",
    "publish:packages": "pnpm -r build && pnpm -r publish --no-git-checks"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
