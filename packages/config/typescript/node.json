{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Node.js / NestJS",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true
  }
}
