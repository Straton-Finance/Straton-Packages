{
  "name": "@straton-finance/blockchain",
  "version": "1.1.1",
  "description": "Contract ABIs, addresses, and stablecoin configs for the Straton RWAFi platform",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Straton-Finance/Straton-Packages.git",
    "directory": "packages/blockchain"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@straton-finance/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "viem": "^2.21.54"
  },
  "peerDependencies": {
    "viem": "^2.0.0"
  },
  "module": "./dist/index.mjs"
}
